{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "types": [
      "nativewind/types"
    ],
    "paths": {
      "@superadmin/*": [
        "./*"
      ],
      "@admin/*": [
        "../admin/*"
      ],
      "@stockaisle/section-card": [
        "../components/section-card/src"
      ],
      "@stockaisle/empty-state": [
        "../components/empty-state/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
