{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start:dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && node ./scripts/rewrite-import-aliases.mjs",
    "build:prod": "tsc -p tsconfig.json && node ./scripts/rewrite-import-aliases.mjs",
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "prod": "npm run build:prod && npm run start:prod",
    "migrate": "node-pg-migrate --envPath .env.local --tsx --tsconfig tsconfig.json --check-order false",
    "migrate:up": "node-pg-migrate up --envPath .env.local --tsx --tsconfig tsconfig.json --check-order false",
    "migrate:down": "node-pg-migrate down --envPath .env.local --tsx --tsconfig tsconfig.json --check-order false",
    "migrate:create": "node-pg-migrate create --envPath .env.local --migration-file-language ts --check-order false",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@faker-js/faker": "^10.3.0",
    "@sentry/node": "^8.26.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jose": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.5.4",
    "@types/node-fetch": "^3.0.3",
    "node-pg-migrate": "^7.6.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
