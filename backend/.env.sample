NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://user:pass@localhost:5432/stockaisle
JWT_SECRET=change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CORS_ORIGIN=http://localhost:8081,http://localhost:19006,http://dev.stockaisle.test,http://dev.stockaisle.test:8081,http://dev.stockaisle.test:19006,https://stockaisle.com,https://admin.stockaisle.com
SSO_PROVIDERS=auth0
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
SSO_GOOGLE_REDIRECT_URI=https://api.stockaisle.com/api/auth/sso/google/callback
SSO_AZUREAD_CLIENT_ID=
SSO_AZUREAD_CLIENT_SECRET=
SSO_AZUREAD_TENANT_ID=
SSO_AZUREAD_REDIRECT_URI=https://api.stockaisle.com/api/auth/sso/azuread/callback
CONVERSATIONAL_ENGINE_URL=http://conversational-engine.svc.stockaisle.internal:8000
SENTRY_DSN=
RESERVATION_TTL_MIN=30
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_REDIRECT_URI=https://api.stockaisle.com/api/auth/sso/auth0/callback
DEFAULT_SSO_ROLE_NAME=staff
S3_REGION=us-east-1
S3_BUCKET=stockaisle-prod-media
S3_PUBLIC_BASE_URL=https://media.stockaisle.com
