{
  "name": "conversational-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn conversational_engine.app.main:app --app-dir src --reload --host 0.0.0.0 --port 8000",
    "start": "uv run uvicorn conversational_engine.app.main:app --app-dir src --host 0.0.0.0 --port 8000",
    "build": "uv run python -m compileall src",
    "test": "uv run pytest",
    "lint": "uv run ruff check .",
    "format": "uv run ruff format .",
    "migrate": "uv run alembic upgrade head"
  }
}
