{
  "family": "stockaisle-prod-engine",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "REPLACE_WITH_ECS_EXECUTION_ROLE_ARN",
  "taskRoleArn": "REPLACE_WITH_ENGINE_TASK_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "conversational-engine",
      "image": "REPLACE_WITH_ENGINE_IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "CONVERSATIONAL_ENGINE_DATABASE_URL",
          "valueFrom": "REPLACE_WITH_ENGINE_DATABASE_SECRET_ARN"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_LLM_API_KEY",
          "valueFrom": "REPLACE_WITH_ENGINE_LLM_SECRET_ARN"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_GEMINI_API_KEY",
          "valueFrom": "REPLACE_WITH_ENGINE_GEMINI_SECRET_ARN"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_DEEPSEEK_API_KEY",
          "valueFrom": "REPLACE_WITH_ENGINE_DEEPSEEK_SECRET_ARN"
        }
      ],
      "environment": [
        {
          "name": "CONVERSATIONAL_ENGINE_ENV",
          "value": "production"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_HOST",
          "value": "0.0.0.0"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_PORT",
          "value": "8000"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_BACKEND_BASE_URL",
          "value": "https://api.stockaisle.com/api"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_LLM_BASE_URL",
          "value": "https://api.openai.com/v1"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_GEMINI_BASE_URL",
          "value": "https://generativelanguage.googleapis.com/v1beta"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_DEEPSEEK_BASE_URL",
          "value": "https://api.deepseek.com/v1"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_MODEL_BEST",
          "value": "gpt-4.1"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_MODEL_OK",
          "value": "gpt-4.1-mini"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_EMBEDDINGS_MODEL",
          "value": "text-embedding-3-small"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_AGENT_MODEL_TIERS",
          "value": "products:best,purchasing:best,inventory:ok,reporting:ok,help:ok,orchestrator_classifier:ok"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_PLANNER_PROVIDER_CHAIN",
          "value": "openai,deepseek"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_EXECUTOR_PROVIDER_CHAIN",
          "value": "openai,deepseek"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_REVIEWER_PROVIDER_CHAIN",
          "value": "openai,deepseek"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_NARRATOR_PROVIDER_CHAIN",
          "value": "openai,deepseek"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_OPENAI_PLANNER_MODEL",
          "value": "gpt-4.1"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_OPENAI_EXECUTOR_MODEL",
          "value": "gpt-4.1-mini"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_OPENAI_REVIEWER_MODEL",
          "value": "gpt-4.1"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_OPENAI_NARRATOR_MODEL",
          "value": "gpt-4.1-mini"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_GEMINI_PLANNER_MODEL",
          "value": "gemini-2.5-flash"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_GEMINI_EXECUTOR_MODEL",
          "value": "gemini-2.5-flash"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_GEMINI_REVIEWER_MODEL",
          "value": "gemini-2.5-flash"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_GEMINI_NARRATOR_MODEL",
          "value": "gemini-2.5-flash"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_DEEPSEEK_PLANNER_MODEL",
          "value": "deepseek-chat"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_DEEPSEEK_EXECUTOR_MODEL",
          "value": "deepseek-chat"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_DEEPSEEK_REVIEWER_MODEL",
          "value": "deepseek-chat"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_DEEPSEEK_NARRATOR_MODEL",
          "value": "deepseek-chat"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_FEATURE_ENABLED",
          "value": "true"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_MUTATIONS_ENABLED",
          "value": "false"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_RETRIEVAL_ENABLED",
          "value": "false"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_CORS_ORIGINS",
          "value": "https://admin.stockaisle.com"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/stockaisle-prod-engine",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
