{
  "family": "stockaisle-prod-engine",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "REPLACE_WITH_ECS_EXECUTION_ROLE_ARN",
  "taskRoleArn": "REPLACE_WITH_ENGINE_TASK_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "conversational-engine",
      "image": "REPLACE_WITH_ENGINE_IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "CONVERSATIONAL_ENGINE_DATABASE_URL",
          "valueFrom": "REPLACE_WITH_ENGINE_DATABASE_SECRET_ARN"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_LLM_API_KEY",
          "valueFrom": "REPLACE_WITH_ENGINE_LLM_SECRET_ARN"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/stockaisle-prod-engine",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
