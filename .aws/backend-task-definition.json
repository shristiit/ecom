{
  "family": "stockaisle-prod-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "REPLACE_WITH_ECS_EXECUTION_ROLE_ARN",
  "taskRoleArn": "REPLACE_WITH_BACKEND_TASK_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "REPLACE_WITH_BACKEND_IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 4000,
          "hostPort": 4000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "REPLACE_WITH_DATABASE_URL_SECRET_ARN"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "REPLACE_WITH_JWT_SECRET_ARN"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "REPLACE_WITH_OPENAI_API_KEY_SECRET_ARN"
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "valueFrom": "REPLACE_WITH_AUTH0_CLIENT_SECRET_ARN"
        },
        {
          "name": "SSO_GOOGLE_CLIENT_SECRET",
          "valueFrom": "REPLACE_WITH_SSO_GOOGLE_CLIENT_SECRET_ARN"
        },
        {
          "name": "SSO_AZUREAD_CLIENT_SECRET",
          "valueFrom": "REPLACE_WITH_SSO_AZUREAD_CLIENT_SECRET_ARN"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "4000"
        },
        {
          "name": "CORS_ORIGIN",
          "value": "https://stockaisle.com,https://admin.stockaisle.com"
        },
        {
          "name": "CONVERSATIONAL_ENGINE_URL",
          "value": "http://conversational-engine.svc.stockaisle.internal:8000"
        },
        {
          "name": "ACCESS_TOKEN_TTL",
          "value": "15m"
        },
        {
          "name": "REFRESH_TOKEN_TTL",
          "value": "7d"
        },
        {
          "name": "OPENAI_MODEL",
          "value": "gpt-4o-mini"
        },
        {
          "name": "OPENAI_BASE_URL",
          "value": "https://api.openai.com/v1"
        },
        {
          "name": "RESERVATION_TTL_MIN",
          "value": "30"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/stockaisle-prod-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
