{
  "name": "admin",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/native-workflow.js start",
    "start:dev": "node ./scripts/native-workflow.js start dev --web",
    "start:browserstack": "node ./scripts/native-workflow.js start browserstack --web",
    "start:prod": "node ./scripts/native-workflow.js start prod --web",
    "build": "expo export --platform web",
    "build:web": "expo export --platform web",
    "build:prod": "expo export --platform web --output-dir dist",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android:dev": "node ./scripts/native-workflow.js run android dev",
    "android:browserstack": "node ./scripts/native-workflow.js build android browserstack",
    "android:prod": "node ./scripts/native-workflow.js build android prod",
    "ios:dev": "node ./scripts/native-workflow.js run ios dev",
    "ios:browserstack": "node ./scripts/native-workflow.js build ios browserstack",
    "ios:prod": "node ./scripts/native-workflow.js build ios prod",
    "build:android": "pnpm android:prod",
    "build:ios": "pnpm ios:prod",
    "serve:prod": "npx serve dist -l 8081",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "pnpm android:dev",
    "ios": "pnpm ios:dev",
    "web": "pnpm start:dev",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gluestack-ui/config": "^1.1.7",
    "@gluestack-ui/themed": "^1.1.73",
    "@gluestack-ui/utils": "^3.0.15",
    "@react-native-aria/dialog": "^0.0.5",
    "@react-native-aria/focus": "0.2.9",
    "@react-native-aria/interactions": "0.2.16",
    "@react-native-aria/overlays": "^0.3.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@stockaisle/empty-state": "workspace:*",
    "@stockaisle/section-card": "workspace:*",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.1.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
