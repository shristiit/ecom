{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["nativewind/types"],
    "paths": {
      "@/*": ["./*"],
      "@stockaisle/section-card": ["../components/section-card/src"],
      "@stockaisle/empty-state": ["../components/empty-state/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
